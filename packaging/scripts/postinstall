#!/bin/bash
set -euo pipefail

user="$(stat -f %Su /dev/console 2>/dev/null || true)"
if [ -z "$user" ] || [ "$user" = "root" ] || [ "$user" = "loginwindow" ]; then
	echo "Agenthail installed. Run agenthail daemon install from the user account that will operate it."
	exit 0
fi

uid="$(id -u "$user")"
home="$(dscl . -read "/Users/$user" NFSHomeDirectory 2>/dev/null | awk '{print $2}')"
run_user() {
	launchctl asuser "$uid" /usr/bin/sudo -u "$user" env HOME="$home" "$@"
}

run_user /usr/local/bin/agenthail daemon install
if [ ! -f "$home/.agenthail/dashboard.json" ]; then
	run_user /usr/local/bin/agenthail dashboard enable --no-open
fi
run_user /Applications/Agenthail.app/Contents/MacOS/Agenthail service enable || true
run_user /usr/bin/open -g -j -a /Applications/Agenthail.app || true

exit 0
